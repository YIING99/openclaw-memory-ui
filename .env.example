# Memory Web UI — Environment Variables
# Copy this file to .env and customize
# Or run: python setup.py

# === Language ===
# Supported: en, zh (add your own in locales/)
LANGUAGE=en

# === Path Configuration ===
# Path to your markdown files directory
MEMORY_DIR=~/memory
# (Optional) Used by reindex subprocess
OPENCLAW_DIR=
OPENCLAW_HOME=~

# === Authentication ===
# Generate hash: python3 -c "import hashlib; print(hashlib.sha256('yourpassword'.encode()).hexdigest())"
MEMORY_UI_PASSWORD_HASH=
# Random secret key for Flask sessions
MEMORY_UI_SECRET_KEY=change-me-to-a-random-string
# Session lifetime in hours
SESSION_LIFETIME_HOURS=72

# === Branding ===
APP_TITLE=Memory UI
APP_SUBTITLE=Markdown Knowledge Base

# === Review System ===
# Set to "false" to disable the review workflow
ENABLE_REVIEW=true
# Comma-separated review statuses (stored in .md frontmatter)
REVIEW_STATUSES=pending,in_review,approved,needs_revision,published
# Which statuses count as "approved"
APPROVED_STATUSES=approved,published

# === Drafts ===
# Folder name for drafts (files moved here when deleting folders)
DRAFTS_FOLDER=drafts

# === Server ===
# For gunicorn
BIND=127.0.0.1:5000
WORKERS=2
# For development (python app.py)
PORT=5000

# === Re-index ===
# Shell command to run after edits (leave empty to disable)
# Example: npx openclaw memory index --force
# Example: python3 /path/to/rebuild.py
REINDEX_COMMAND=
REINDEX_TIMEOUT=120
