# OpenClaw Memory Web UI — Environment Variables
# Copy this file to .env and customize

# === Path Configuration ===
# Path to your OpenClaw memory/ directory
MEMORY_DIR=~/.openclaw/workspace/memory
# Path to your OpenClaw installation
OPENCLAW_DIR=~/.openclaw
# HOME directory for OpenClaw re-index command
OPENCLAW_HOME=~

# === Authentication ===
# Generate hash: python3 -c "import hashlib; print(hashlib.sha256('yourpassword'.encode()).hexdigest())"
MEMORY_UI_PASSWORD_HASH=
# Random secret key for Flask sessions
MEMORY_UI_SECRET_KEY=change-me-to-a-random-string
# Session lifetime in hours
SESSION_LIFETIME_HOURS=72

# === Branding ===
APP_TITLE=Memory UI
APP_SUBTITLE=OpenClaw Knowledge Base

# === Features ===
# Set to "false" to disable the review workflow
ENABLE_REVIEW=true

# === Server ===
# For gunicorn
BIND=127.0.0.1:5000
WORKERS=2
# For development (python app.py)
PORT=5000

# === Re-index ===
REINDEX_TIMEOUT=120
